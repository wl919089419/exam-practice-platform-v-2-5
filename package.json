{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "tauri": "tauri",
    "postinstall": "node -e \"const fs = require('fs'); const path = require('path'); const src = path.join('node_modules', 'monaco-editor', 'min', 'vs'); const dest = path.join('public', 'monaco', 'vs'); if (fs.existsSync(src)) { fs.mkdirSync(path.dirname(dest), { recursive: true }); fs.cpSync(src, dest, { recursive: true }); console.log('Copied monaco-editor files to public/monaco/vs'); } else { console.warn('monaco-editor not found, skipping copy'); }\""
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.10.1",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "error-stack-parser": "^2.1.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "stackframe": "^1.3.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
